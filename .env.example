# Copie para .env na raiz:  cp .env.example .env
# Usado pelo docker compose (substituição de variáveis)

# PostgreSQL (host → container; dentro da rede Docker a porta interna é sempre 5432)
POSTGRES_HOST_PORT=5434
POSTGRES_USER=edusaas
POSTGRES_PASSWORD=edusaas
POSTGRES_DB=edusaas

# Serviços
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Backend
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-in-production-edusaas-dev
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# IA — geração de provas via Claude Code CLI (rodado dentro do container backend)
# Use a SUA ASSINATURA (sem chave de API): rode `claude setup-token` no host e
# cole aqui o token gerado (formato sk-ant-oat01-...).
CLAUDE_CODE_OAUTH_TOKEN=
# Alternativa: chave de API (https://console.anthropic.com/settings/keys).
ANTHROPIC_API_KEY=
# Opcional: modelo específico (ex.: claude-sonnet-4-6). Vazio usa o padrão do CLI.
CLAUDE_MODEL=

# Frontend (navegador; rotas server-side no Docker usam API_URL=http://backend:8000 via compose)
NEXT_PUBLIC_API_URL=http://localhost:8000
